# ==============================================
# Persona Configuration
# Copy this file to .env before running the app.
# ==============================================

# ----------------------------------------------
# 1. Hugging Face Authentication (REQUIRED)
# ----------------------------------------------
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ----------------------------------------------
# 2. LLM Model Configuration (Optional)
# ----------------------------------------------
# Primary Model: The main high-performance model to use.
# Default: Qwen/Qwen2.5-7B-Instruct
PRIMARY_MODEL=Qwen/Qwen2.5-7B-Instruct

# Fallback Model: Backup model if the primary fails.
# Default: mistralai/Mistral-7B-Instruct-v0.2
FALLBACK_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# LLM Provider: Currently only 'hf' (Hugging Face) is supported.
LLM_PROVIDER=hf

# ----------------------------------------------
# 3. System Reliability (Debugging)
# ----------------------------------------------
# Set to 'true' to force the system to use the fallback model immediately.
# Useful for testing fallback logic without waiting for a failure.
FORCE_FALLBACK=false

# ----------------------------------------------
# 4. Frontend Configuration (For Docker Compose)
# ----------------------------------------------
# URL of the backend API.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
